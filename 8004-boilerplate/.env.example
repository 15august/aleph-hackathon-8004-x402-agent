# Required: Your wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Optional: Custom RPC URL (defaults to public Avalanche RPC)
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Optional: Backend polling interval in milliseconds
POLL_INTERVAL=10000

# ===========================================
# AI API Keys (for agent-backend)
# ===========================================

# OpenAI (if using handlers.example.js)
OPENAI_API_KEY=sk-...

# Anthropic (if using Claude)
ANTHROPIC_API_KEY=sk-ant-...
